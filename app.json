{
  "expo": {
    "name": "DIFM Rural",
    "slug": "difm-rural",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/do-it-for-me-rural-app-icon-1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/do-it-for-me-rural-app-icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d6a4f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "nz.co.difmrural.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/do-it-for-me-rural-app-icon-1024.png",
        "backgroundColor": "#2d6a4f"
      },
      "package": "nz.co.difmrural.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD-f2dRi2_mLQndyWLf1zbOHvfi9MXb7IU"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "DIFM Rural uses your location to find nearby jobs and verify job completion.",
          "locationWhenInUsePermission": "DIFM Rural uses your location to find nearby jobs and services."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DIFM Rural lets providers choose service photos and create service drafts from flyers or screenshots.",
          "cameraPermission": "DIFM Rural lets providers take photos of service flyers, signs, and notes to create draft listings.",
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8f162c89-3416-4f10-94a6-108bfc7b8c49"
      }
    },
    "owner": "difmrural"
  }
}
